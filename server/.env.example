# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/family_trees

# Authentication
# Password for the /api/auth endpoint
PASSWORD=your_secure_password_here

# JWT Secret (optional - defaults to PASSWORD if not set)
JWT_SECRET=your_jwt_secret_key_here

# Frontend Configuration
# The stable production frontend URL (without trailing slash)
# Example: https://ak-psi-nu-chapter-portal.vercel.app
FRONTEND_URL=https://ak-psi-nu-chapter-portal.vercel.app
